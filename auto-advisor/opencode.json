{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "fetch": {
      "type": "local",
      "command": ["npx", "-y", "@anthropic/mcp-fetch"],
      "enabled": true,
      "timeout": 15000
    },
    "browser": {
      "type": "local",
      "command": ["agent-browser", "mcp", "--connect", "9222"],
      "enabled": true,
      "timeout": 30000
    }
  }
}
